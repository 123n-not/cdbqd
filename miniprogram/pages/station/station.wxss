/* ============================================
   投放点详情 & 充电宝列表
   ============================================ */

.page-station {
  min-height: 100vh;
  background: var(--bg-page);
  padding-bottom: 40rpx;
}

/* --- 站点头部 --- */
.station-hero {
  background: linear-gradient(160deg, #4CAF50 0%, #66BB6A 40%, #43A047 100%);
  padding: 36rpx 32rpx 40rpx;
  margin: 16rpx 24rpx 0;
  border-radius: var(--radius-lg);
  box-shadow: 0 8rpx 32rpx rgba(76,175,80,0.25);
  color: #fff;
}

.hero-name {
  font-size: 38rpx;
  font-weight: 800;
  letter-spacing: 1rpx;
}

.hero-address, .hero-desc {
  margin-top: 14rpx;
  font-size: 26rpx;
  color: rgba(255,255,255,0.85);
  line-height: 1.5;
}

/* --- 统计区 --- */
.hero-stats {
  display: flex;
  align-items: center;
  justify-content: space-around;
  margin-top: 28rpx;
  padding: 24rpx 0;
  background: rgba(255,255,255,0.15);
  border-radius: var(--radius-md);
}

.hero-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.hero-stat-divider {
  width: 2rpx;
  height: 48rpx;
  background: rgba(255,255,255,0.25);
}

.hero-stat-num {
  font-size: 44rpx;
  font-weight: 800;
  color: #fff;
}

.hero-stat-num.highlight {
  color: #fff;
}

.hero-stat-num.secondary {
  opacity: 0.7;
}

.hero-stat-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.7);
  margin-top: 6rpx;
}

/* --- 进度条 --- */
.hero-progress {
  display: flex;
  align-items: center;
  margin-top: 20rpx;
  gap: 16rpx;
}

.progress-bar {
  flex: 1;
  height: 10rpx;
  background: rgba(255,255,255,0.25);
  border-radius: 5rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: #fff;
  border-radius: 5rpx;
  transition: width 0.6s ease;
}

.progress-text {
  font-size: 22rpx;
  color: rgba(255,255,255,0.75);
  flex-shrink: 0;
}

/* --- 骨架 --- */
.station-hero-skeleton {
  background: #fff;
  padding: 36rpx 32rpx 40rpx;
  margin: 16rpx 24rpx 0;
  border-radius: var(--radius-lg);
}

.station-skeleton {
  background: #fff;
  border-radius: var(--radius-md);
  padding: 28rpx;
  margin-bottom: 18rpx;
  box-shadow: var(--shadow-sm);
}

/* --- 充电宝卡片 --- */
.pb-card {
  display: flex;
  align-items: stretch;
  background: #fff;
  border-radius: var(--radius-md);
  margin-bottom: 18rpx;
  padding: 24rpx;
  box-shadow: var(--shadow-sm);
  transition: all 0.2s;
  gap: 20rpx;
}

.pb-card:active {
  transform: scale(0.985);
  box-shadow: var(--shadow-md);
}

/* 电池图标列 */
.pb-battery-col {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  flex-shrink: 0;
}

.pb-battery-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 5rpx solid;
}

.pb-battery-icon.high {
  background: #E8F5E9;
  border-color: #4CAF50;
}

.pb-battery-icon.mid {
  background: #FFF8E1;
  border-color: #FF9800;
}

.pb-battery-icon.low {
  background: #FFEBEE;
  border-color: #FF5252;
}

.pb-battery-num {
  font-size: 36rpx;
  font-weight: 800;
  line-height: 1;
}

.pb-battery-icon.high .pb-battery-num { color: #4CAF50; }
.pb-battery-icon.mid  .pb-battery-num { color: #FF9800; }
.pb-battery-icon.low  .pb-battery-num { color: #FF5252; }

.pb-battery-pct {
  font-size: 20rpx;
  font-weight: 600;
  opacity: 0.6;
}

/* 电池条 */
.pb-battery-bar-bg {
  width: 12rpx;
  height: 80rpx;
  background: #eef0f4;
  border-radius: 6rpx;
  overflow: hidden;
  position: relative;
}

.pb-battery-bar-fill {
  width: 100%;
  position: absolute;
  bottom: 0;
  border-radius: 6rpx;
  transition: height 0.4s ease;
}

.pb-battery-bar-fill.high { background: #4CAF50; }
.pb-battery-bar-fill.mid  { background: #FF9800; }
.pb-battery-bar-fill.low  { background: #FF5252; }

/* 信息区 */
.pb-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 14rpx;
}

.pb-info-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.pb-label {
  font-size: 24rpx;
  color: var(--text-hint);
  min-width: 72rpx;
}

.pb-value {
  font-size: 26rpx;
  color: var(--text-primary);
  font-weight: 500;
}

/* 借用箭头 */
.pb-rent-arrow {
  display: flex;
  align-items: center;
  font-size: 36rpx;
  color: var(--text-hint);
  font-weight: 300;
  flex-shrink: 0;
  padding: 0 4rpx;
}

/* --- 空状态图标 --- */
.empty-icon-large {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}
