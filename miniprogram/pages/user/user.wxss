/* ============================================
   个人中心页
   ============================================ */

.page-user {
  min-height: 100vh;
  background: var(--bg-page);
  padding-bottom: 60rpx;
}

/* --- 头部 --- */
.user-hero {
  background: linear-gradient(160deg, #4CAF50 0%, #66BB6A 40%, #43A047 100%);
  padding: 60rpx 28rpx 32rpx;
  position: relative;
  overflow: hidden;
  color: #fff;
}

.hero-bg-decor {
  position: absolute;
  top: -60rpx;
  right: -40rpx;
  width: 240rpx;
  height: 240rpx;
  background: rgba(255,255,255,0.06);
  border-radius: 50%;
  pointer-events: none;
}

.hero-main {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  z-index: 1;
}

.avatar-wrap {
  position: relative;
  margin-bottom: 20rpx;
}

.avatar-circle {
  width: 130rpx;
  height: 130rpx;
  background: rgba(255,255,255,0.95);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.12);
}

.avatar-letter {
  font-size: 56rpx;
  font-weight: 800;
  color: var(--primary);
}

.avatar-badge {
  position: absolute;
  right: 4rpx;
  bottom: 4rpx;
  width: 36rpx;
  height: 36rpx;
  background: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: var(--primary);
  font-weight: bold;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

.user-name {
  font-size: 36rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
}

.user-phone {
  font-size: 26rpx;
  color: rgba(255,255,255,0.75);
  margin-top: 6rpx;
}

.user-id-tag {
  margin-top: 10rpx;
  padding: 6rpx 20rpx;
  background: rgba(255,255,255,0.18);
  border-radius: var(--radius-full);
}

.user-id-tag text {
  font-size: 22rpx;
  color: rgba(255,255,255,0.8);
}

/* --- 统计区 --- */
.hero-stats {
  display: flex;
  align-items: center;
  justify-content: space-around;
  margin-top: 28rpx;
  padding: 24rpx 0;
  background: rgba(255,255,255,0.12);
  border-radius: var(--radius-md);
  position: relative;
  z-index: 1;
}

.hero-stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.hero-stat-divider {
  width: 2rpx;
  height: 40rpx;
  background: rgba(255,255,255,0.2);
}

.hero-stat-num {
  font-size: 36rpx;
  font-weight: 800;
}

.hero-stat-label {
  font-size: 22rpx;
  opacity: 0.7;
  margin-top: 4rpx;
}

/* --- 菜单 --- */
.menu-section {
  padding: 24rpx;
}

.menu-group {
  background: #fff;
  border-radius: var(--radius-md);
  margin-bottom: 18rpx;
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid var(--border);
  transition: background 0.15s;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: #f9fafb;
}

.menu-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex: 1;
}

.menu-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
}

.icon-green  { background: #E8F5E9; }
.icon-orange { background: #FFF3E0; }
.icon-blue   { background: #E3F2FD; }
.icon-purple { background: #F3E5F5; }
.icon-gray   { background: #F5F5F5; }

.menu-text-wrap {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.menu-label {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.menu-desc {
  font-size: 24rpx;
  color: var(--text-hint);
}

.menu-right {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.menu-arrow {
  font-size: 32rpx;
  color: var(--text-hint);
  font-weight: 300;
}

/* --- 退出 --- */
.logout-area {
  padding: 20rpx 24rpx;
}

.logout-area .btn {
  height: 92rpx;
  font-size: 30rpx;
}

/* --- 底部 --- */
.user-footer {
  text-align: center;
  padding: 30rpx;
}

.user-footer text {
  font-size: 24rpx;
  color: var(--text-hint);
}

.footer-divider {
  margin: 0 12rpx;
}
