/* ============================================
   归还充电宝页
   ============================================ */

.page-return {
  min-height: 100vh;
  background: var(--bg-page);
  padding: 0 24rpx 140rpx;
}

/* --- 加载 --- */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
  gap: 24rpx;
}

.loading-icon {
  font-size: 100rpx;
}

.loading-text {
  font-size: 28rpx;
  color: var(--text-hint);
}

/* --- 归还头部 --- */
.return-header-card {
  text-align: center;
  padding: 36rpx 0 24rpx;
}

.return-icon-wrap {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #FF9800, #F57C00);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(255,152,0,0.3);
}

.return-icon {
  font-size: 48rpx;
}

.return-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.return-subtitle {
  display: block;
  font-size: 26rpx;
  color: var(--text-hint);
  margin-top: 8rpx;
}

/* --- 订单摘要 --- */
.order-summary-card {
  background: #fff;
  border-radius: var(--radius-md);
  padding: 24rpx 28rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-sm);
}

.summary-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.summary-row:last-of-type {
  border-bottom: none;
}

.summary-label {
  font-size: 26rpx;
  color: var(--text-hint);
}

.summary-value {
  font-size: 26rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.summary-tag-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 14rpx;
  padding-top: 14rpx;
  border-top: 1rpx solid var(--border);
}

/* --- 选择列表 --- */
.station-select-list {
  margin-bottom: 20rpx;
}

.select-card {
  display: flex;
  align-items: stretch;
  background: #fff;
  border-radius: var(--radius-md);
  margin-bottom: 16rpx;
  padding: 24rpx 16rpx 24rpx 20rpx;
  box-shadow: var(--shadow-sm);
  border: 3rpx solid transparent;
  gap: 16rpx;
  transition: all 0.2s;
}

.select-card.selected {
  border-color: var(--primary);
  background: #F1F8E9;
  box-shadow: 0 4rpx 20rpx rgba(76,175,80,0.12);
}

.select-indicator {
  display: flex;
  align-items: center;
  flex-shrink: 0;
}

.radio-circle {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 3rpx solid #ccc;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #fff;
  transition: all 0.2s;
}

.radio-circle.checked {
  background: var(--primary);
  border-color: var(--primary);
}

.select-body {
  flex: 1;
  min-width: 0;
}

.select-name-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.select-name {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary);
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tag {
  padding: 4rpx 16rpx;
  border-radius: var(--radius-full);
  font-size: 22rpx;
  font-weight: 600;
  flex-shrink: 0;
  margin-left: 12rpx;
}

.tag-available {
  background: var(--primary-bg);
  color: var(--primary);
}

.tag-full {
  background: #FFEBEE;
  color: var(--danger);
}

.select-addr {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.select-slots-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.mini-progress {
  flex: 1;
  height: 6rpx;
  background: #eef0f4;
  border-radius: 3rpx;
  overflow: hidden;
}

.mini-progress-fill {
  height: 100%;
  background: var(--primary);
  border-radius: 3rpx;
  transition: width 0.4s ease;
}

.mini-progress-text {
  font-size: 22rpx;
  color: var(--text-hint);
  flex-shrink: 0;
}

/* --- 温馨提示 --- */
.tips-banner {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  padding: 20rpx 24rpx;
  background: #FFF8E1;
  border-radius: var(--radius-md);
  border: 1rpx solid #FFE082;
  margin-bottom: 20rpx;
}

.tips-icon {
  font-size: 28rpx;
  flex-shrink: 0;
}

.tips-text {
  font-size: 24rpx;
  color: #8D6E00;
  line-height: 1.6;
}

/* --- 空状态 --- */
.empty-icon-large {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

/* --- 底部按钮 --- */
.btn-row {
  display: flex;
  gap: 20rpx;
}

.btn-row .btn {
  height: 92rpx;
  font-size: 30rpx;
}

.btn-disabled {
  opacity: 0.5;
  pointer-events: none;
}
