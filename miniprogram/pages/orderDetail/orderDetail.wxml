<view class="order-detail-container" wx:if="{{!loading && order}}">
    <view class="status-card">
        <view class="status-icon">📦</view>
        <view class="status-text" style="color: {{getStatusColor(order.status)}}">
            {{getStatusText(order.status)}}
        </view>
    </view>

    <view class="info-card">
        <view class="card-title">订单信息</view>

        <view class="info-row">
            <text class="info-label">订单号：</text>
            <text class="info-value">{{order.id}}</text>
        </view>

        <view class="info-row">
            <text class="info-label">充电宝编号：</text>
            <text class="info-value">{{order.powerBankSerialNumber}}</text>
        </view>

        <view class="info-row">
            <text class="info-label">投放点：</text>
            <text class="info-value">{{order.stationName}}</text>
        </view>

        <view class="info-row">
            <text class="info-label">借用时间：</text>
            <text class="info-value">{{order.rentTime}}</text>
        </view>

        <view class="info-row" wx:if="{{order.returnTime}}">
            <text class="info-label">归还时间：</text>
            <text class="info-value">{{order.returnTime}}</text>
        </view>

        <view class="info-row" wx:if="{{order.amount}}">
            <text class="info-label">费用：</text>
            <text class="info-value amount">¥{{order.amount}}</text>
        </view>
    </view>

    <view class="info-card" wx:if="{{order.status === 1}}">
        <view class="card-title">使用时长</view>

        <view class="duration-display">
            <text class="duration-text">{{order.duration || '计算中...'}}</text>
        </view>

        <view class="tips-text">
            <text>费用将根据实际使用时长计算</text>
        </view>
    </view>

    <view class="button-group" wx:if="{{order.status === 1}}">
        <button class="return-btn" bindtap="onReturnOrder">去归还</button>
    </view>
</view>

<view class="loading-container" wx:if="{{loading}}">
    <text class="loading-text">加载中...</text>
</view>