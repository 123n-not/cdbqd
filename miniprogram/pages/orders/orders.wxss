.orders-container {
    min-height: 100vh;
    background: #f5f5f5;
    padding: 20rpx 30rpx;
    box-sizing: border-box;
}

.order-list {
    display: flex;
    flex-direction: column;
    gap: 20rpx;
}

.order-card {
    background: #fff;
    border-radius: 16rpx;
    padding: 30rpx;
    box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.order-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 24rpx;
    padding-bottom: 20rpx;
    border-bottom: 1rpx solid #f0f0f0;
}

.order-id {
    font-size: 26rpx;
    color: #666;
}

.order-status {
    font-size: 28rpx;
    font-weight: bold;
    padding: 8rpx 20rpx;
    border-radius: 20rpx;
    background: #f5f5f5;
}

.order-body {
    margin-bottom: 20rpx;
}

.order-info {
    display: flex;
    margin-bottom: 16rpx;
    align-items: center;
}

.info-label {
    font-size: 26rpx;
    color: #999;
    min-width: 140rpx;
}

.info-value {
    font-size: 26rpx;
    color: #333;
    flex: 1;
}

.info-value.amount {
    font-size: 32rpx;
    font-weight: bold;
    color: #4CAF50;
}

.order-footer {
    padding-top: 20rpx;
    border-top: 1rpx solid #f0f0f0;
}

.return-btn {
    width: 100%;
    height: 72rpx;
    background: #4CAF50;
    color: #fff;
    border-radius: 12rpx;
    font-size: 28rpx;
    font-weight: bold;
    border: none;
}

.return-btn::after {
    border: none;
}

.empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 150rpx 0;
}

.empty-icon {
    font-size: 120rpx;
    margin-bottom: 30rpx;
}

.empty-text {
    font-size: 28rpx;
    color: #999;
}

.loading-state {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 100rpx 0;
}

.loading-text {
    font-size: 28rpx;
    color: #999;
}