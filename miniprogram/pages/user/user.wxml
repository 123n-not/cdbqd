<view class="user-container">
    <view class="user-header">
        <view class="avatar">
            <text class="avatar-text">{{userInfo ? userInfo.nickname ? userInfo.nickname.charAt(0) : userInfo.username.charAt(0) : 'U'}}</text>
        </view>
        <view class="user-info">
            <text class="username">{{userInfo ? userInfo.nickname || userInfo.username : '未登录'}}</text>
            <text class="user-phone" wx:if="{{userInfo && userInfo.phone}}">{{userInfo.phone}}</text>
        </view>
    </view>

    <view class="menu-section">
        <view class="menu-item" bindtap="onOrdersTap">
            <view class="menu-left">
                <text class="menu-icon">📋</text>
                <text class="menu-text">我的订单</text>
            </view>
            <text class="menu-arrow">›</text>
        </view>

        <view class="menu-item" bindtap="onAboutTap">
            <view class="menu-left">
                <text class="menu-icon">ℹ️</text>
                <text class="menu-text">关于我们</text>
            </view>
            <text class="menu-arrow">›</text>
        </view>
    </view>

    <view class="logout-section">
        <button class="logout-btn" bindtap="onLogout">退出登录</button>
    </view>

    <view class="footer">
        <text class="footer-text">共享充电宝系统 v1.0</text>
    </view>
</view>