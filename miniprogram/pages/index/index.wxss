/* ============================================
   首页 — 投放点地图 & 列表
   ============================================ */

.page-index {
  min-height: 100vh;
  background: var(--bg-page);
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* --- 顶部横幅 --- */
.hero-banner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  margin: 16rpx 24rpx 0;
  background: linear-gradient(135deg, #4CAF50 0%, #66BB6A 40%, #43A047 100%);
  border-radius: var(--radius-lg);
  box-shadow: 0 8rpx 32rpx rgba(76,175,80,0.25);
}

.hero-content {
  display: flex;
  flex-direction: column;
}

.hero-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #fff;
  letter-spacing: 2rpx;
}

.hero-subtitle {
  font-size: 24rpx;
  color: rgba(255,255,255,0.85);
  margin-top: 6rpx;
}

.hero-icon {
  font-size: 80rpx;
}

/* --- 搜索区 --- */
.search-section {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  gap: 16rpx;
}

.search-box {
  flex: 1;
  display: flex;
  align-items: center;
  height: 76rpx;
  background: #fff;
  border-radius: var(--radius-full);
  padding: 0 8rpx 0 28rpx;
  box-shadow: var(--shadow-sm);
  border: 2rpx solid transparent;
  transition: border-color 0.2s;
}

.search-box:focus-within {
  border-color: var(--primary);
  box-shadow: 0 0 0 6rpx rgba(76,175,80,0.06);
}

.search-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
  opacity: 0.5;
}

.search-input {
  flex: 1;
  height: 100%;
  font-size: 28rpx;
  color: var(--text-primary);
}

.search-clear {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #eee;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #999;
  margin-right: 8rpx;
}

.scan-btn {
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4CAF50, #43A047);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(76,175,80,0.3);
}

.scan-icon {
  font-size: 36rpx;
}

/* --- 快捷标签 --- */
.quick-tags {
  display: flex;
  gap: 16rpx;
  padding: 0 24rpx 20rpx;
}

.quick-tag {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 12rpx 24rpx;
  background: #fff;
  border-radius: var(--radius-full);
  font-size: 26rpx;
  color: var(--text-secondary);
  box-shadow: var(--shadow-sm);
  transition: all 0.2s;
}

.quick-tag.active {
  background: var(--primary);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(76,175,80,0.3);
}

.tag-icon {
  font-size: 24rpx;
}

/* --- 地图 --- */
.map-section {
  position: relative;
  width: 100%;
  height: 520rpx;
  margin: 0 24rpx;
  width: calc(100% - 48rpx);
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-md);
}

.map-locate-btn {
  position: absolute;
  right: 20rpx;
  bottom: 40rpx;
  width: 72rpx;
  height: 72rpx;
  background: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  box-shadow: var(--shadow-md);
}

.map-locate-btn:active {
  transform: scale(0.9);
}

.map-stats {
  position: absolute;
  top: 16rpx;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(0,0,0,0.65);
  backdrop-filter: blur(8px);
  padding: 10rpx 24rpx;
  border-radius: var(--radius-full);
}

.map-stats-text {
  color: #fff;
  font-size: 24rpx;
}

/* --- 站点列表区 --- */
.station-section {
  padding: 24rpx 24rpx 0;
}

.section-count {
  font-size: 26rpx;
  color: var(--text-hint);
}

/* --- 骨架屏 --- */
.station-skeleton {
  background: #fff;
  border-radius: var(--radius-md);
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-sm);
}

/* --- 站点卡片 --- */
.station-card {
  display: flex;
  background: #fff;
  border-radius: var(--radius-md);
  margin-bottom: 18rpx;
  box-shadow: var(--shadow-sm);
  overflow: hidden;
  transition: all 0.2s;
}

.station-card:active {
  transform: scale(0.985);
  box-shadow: var(--shadow-md);
}

.station-accent {
  width: 8rpx;
  flex-shrink: 0;
  border-radius: 4rpx;
  margin: 24rpx 0 24rpx 20rpx;
}

.station-body {
  flex: 1;
  padding: 24rpx 20rpx 24rpx 20rpx;
}

.station-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.station-name-row {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.station-name {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.station-slots {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-left: 16rpx;
}

.slots-ring {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 5rpx solid var(--primary);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.slots-num {
  font-size: 30rpx;
  font-weight: 800;
  color: var(--primary);
  line-height: 1;
}

.slots-total {
  font-size: 20rpx;
  color: var(--text-hint);
  line-height: 1;
}

.slots-label {
  font-size: 20rpx;
  color: var(--text-hint);
  margin-top: 6rpx;
}

.station-address {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.addr-icon {
  font-size: 26rpx;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.addr-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.5;
}

.station-desc {
  margin-bottom: 16rpx;
  padding: 12rpx 16rpx;
  background: #fafbfc;
  border-radius: var(--radius-sm);
}

.desc-text {
  font-size: 24rpx;
  color: var(--text-hint);
  line-height: 1.5;
}

.station-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--border);
}

.battery-indicator {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.battery-dots {
  display: flex;
  gap: 6rpx;
}

.battery-dot {
  width: 12rpx;
  height: 20rpx;
  border-radius: 3rpx;
  transition: background 0.3s;
}

.battery-text {
  font-size: 24rpx;
  color: var(--primary);
  font-weight: 500;
}

.no-slot-text {
  font-size: 24rpx;
  color: var(--text-hint);
}

.station-arrow {
  font-size: 32rpx;
  color: var(--text-hint);
  font-weight: 300;
}

/* --- 空状态 --- */
.empty-icon-large {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}
