.index-container {
    min-height: 100vh;
    background: #f5f5f5;
}

.search-bar {
    display: flex;
    align-items: center;
    padding: 20rpx 30rpx;
    background: #fff;
    position: sticky;
    top: 0;
    z-index: 100;
}

.search-input {
    flex: 1;
    height: 72rpx;
    background: #f5f5f5;
    border-radius: 36rpx;
    padding: 0 30rpx;
    font-size: 28rpx;
    margin-right: 20rpx;
}

.search-btn {
    width: 120rpx;
    height: 72rpx;
    background: #4CAF50;
    color: #fff;
    border-radius: 36rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 28rpx;
}

.map-section {
    width: 100%;
    height: 400rpx;
    background: #e0e0e0;
}

.map-container {
    width: 100%;
    height: 100%;
}

.station-list {
    padding: 20rpx 30rpx;
}

.station-card {
    background: #fff;
    border-radius: 16rpx;
    padding: 30rpx;
    margin-bottom: 20rpx;
    box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.station-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20rpx;
}

.station-name {
    font-size: 32rpx;
    font-weight: bold;
    color: #333;
}

.station-status {
    display: flex;
    align-items: baseline;
}

.available-count {
    font-size: 36rpx;
    font-weight: bold;
    color: #4CAF50;
}

.total-count {
    font-size: 24rpx;
    color: #999;
}

.station-info {
    margin-bottom: 16rpx;
}

.info-text {
    font-size: 26rpx;
    color: #666;
    line-height: 1.5;
}

.station-desc {
    margin-bottom: 20rpx;
}

.desc-text {
    font-size: 24rpx;
    color: #999;
    line-height: 1.5;
}

.station-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 20rpx;
    border-top: 1rpx solid #f0f0f0;
}

.footer-text {
    font-size: 26rpx;
    color: #4CAF50;
}

.arrow {
    font-size: 40rpx;
    color: #999;
}

.empty-state,
.loading-state {
    text-align: center;
    padding: 100rpx 0;
}

.empty-text,
.loading-text {
    font-size: 28rpx;
    color: #999;
}