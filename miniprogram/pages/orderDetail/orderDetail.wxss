.order-detail-container {
    min-height: 100vh;
    background: #f5f5f5;
    padding: 20rpx 30rpx 120rpx;
    box-sizing: border-box;
}

.status-card {
    background: linear-gradient(135deg, #4CAF50 0%, #45a049 100%);
    border-radius: 16rpx;
    padding: 60rpx 30rpx;
    text-align: center;
    margin-bottom: 20rpx;
    box-shadow: 0 4rpx 16rpx rgba(76, 175, 80, 0.3);
}

.status-icon {
    font-size: 80rpx;
    margin-bottom: 20rpx;
}

.status-text {
    font-size: 36rpx;
    font-weight: bold;
    color: #fff;
}

.info-card {
    background: #fff;
    border-radius: 16rpx;
    padding: 30rpx;
    margin-bottom: 20rpx;
    box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.card-title {
    font-size: 32rpx;
    font-weight: bold;
    color: #333;
    margin-bottom: 24rpx;
    padding-bottom: 16rpx;
    border-bottom: 1rpx solid #f0f0f0;
}

.info-row {
    display: flex;
    margin-bottom: 24rpx;
    align-items: center;
}

.info-label {
    font-size: 28rpx;
    color: #666;
    min-width: 160rpx;
}

.info-value {
    font-size: 28rpx;
    color: #333;
    flex: 1;
}

.info-value.amount {
    font-size: 36rpx;
    font-weight: bold;
    color: #4CAF50;
}

.duration-display {
    text-align: center;
    padding: 40rpx 0;
}

.duration-text {
    font-size: 48rpx;
    font-weight: bold;
    color: #4CAF50;
}

.tips-text {
    text-align: center;
    font-size: 24rpx;
    color: #999;
    padding-top: 20rpx;
    border-top: 1rpx solid #f0f0f0;
}

.fee-display {
    text-align: center;
    padding: 20rpx 0;
}

.fee-label {
    font-size: 28rpx;
    color: #666;
}

.fee-amount {
    font-size: 48rpx;
    font-weight: bold;
    color: #FF5722;
}

.button-group {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 20rpx 30rpx;
    background: #fff;
    box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.return-btn {
    width: 100%;
    height: 88rpx;
    background: #4CAF50;
    color: #fff;
    border-radius: 12rpx;
    font-size: 32rpx;
    font-weight: bold;
    border: none;
}

.return-btn::after {
    border: none;
}

.loading-container {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    background: #f5f5f5;
}

.loading-text {
    font-size: 28rpx;
    color: #999;
}