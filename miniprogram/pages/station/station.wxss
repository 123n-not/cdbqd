.station-container {
    min-height: 100vh;
    background: #f5f5f5;
    padding: 20rpx 30rpx;
    box-sizing: border-box;
}

.station-info-card {
    background: #fff;
    border-radius: 16rpx;
    padding: 30rpx;
    margin-bottom: 20rpx;
    box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.station-header {
    margin-bottom: 24rpx;
    padding-bottom: 20rpx;
    border-bottom: 1rpx solid #f0f0f0;
}

.station-name {
    font-size: 36rpx;
    font-weight: bold;
    color: #333;
}

.info-row {
    display: flex;
    margin-bottom: 16rpx;
    align-items: flex-start;
}

.info-label {
    font-size: 28rpx;
    color: #666;
    min-width: 120rpx;
}

.info-value {
    font-size: 28rpx;
    color: #333;
    flex: 1;
    line-height: 1.5;
}

.info-value.highlight {
    color: #4CAF50;
    font-weight: bold;
    font-size: 32rpx;
}

.powerbank-section {
    margin-top: 30rpx;
}

.section-title {
    font-size: 32rpx;
    font-weight: bold;
    color: #333;
    margin-bottom: 20rpx;
    padding-left: 10rpx;
    border-left: 6rpx solid #4CAF50;
}

.powerbank-list {
    display: flex;
    flex-direction: column;
    gap: 20rpx;
}

.powerbank-card {
    background: #fff;
    border-radius: 16rpx;
    padding: 30rpx;
    box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.powerbank-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20rpx;
}

.powerbank-id {
    font-size: 28rpx;
    color: #333;
    font-weight: 500;
}

.battery-level {
    background: #4CAF50;
    color: #fff;
    padding: 8rpx 20rpx;
    border-radius: 20rpx;
    font-size: 24rpx;
}

.battery-text {
    font-weight: bold;
}

.powerbank-body {
    margin-bottom: 20rpx;
}

.status-badge {
    display: inline-block;
    background: #e8f5e9;
    color: #4CAF50;
    padding: 8rpx 20rpx;
    border-radius: 8rpx;
    font-size: 24rpx;
}

.status-text {
    font-weight: 500;
}

.powerbank-footer {
    text-align: center;
    padding-top: 20rpx;
    border-top: 1rpx solid #f0f0f0;
}

.rent-btn {
    font-size: 28rpx;
    color: #4CAF50;
    font-weight: 500;
}

.empty-state,
.loading-state {
    text-align: center;
    padding: 100rpx 0;
}

.empty-text,
.loading-text {
    font-size: 28rpx;
    color: #999;
}