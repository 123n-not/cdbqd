.return-container {
    min-height: 100vh;
    background: #f5f5f5;
    padding: 20rpx 30rpx 120rpx;
    box-sizing: border-box;
}

.info-card {
    background: #fff;
    border-radius: 16rpx;
    padding: 30rpx;
    margin-bottom: 20rpx;
    box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.card-title {
    font-size: 32rpx;
    font-weight: bold;
    color: #333;
    margin-bottom: 24rpx;
    padding-bottom: 16rpx;
    border-bottom: 1rpx solid #f0f0f0;
}

.info-row {
    display: flex;
    margin-bottom: 20rpx;
    align-items: center;
}

.info-label {
    font-size: 28rpx;
    color: #666;
    min-width: 160rpx;
}

.info-value {
    font-size: 28rpx;
    color: #333;
    flex: 1;
}

.info-value.status {
    color: #4CAF50;
    font-weight: 500;
}

.station-section {
    margin-bottom: 20rpx;
}

.section-title {
    font-size: 32rpx;
    font-weight: bold;
    color: #333;
    margin-bottom: 20rpx;
    padding-left: 10rpx;
    border-left: 6rpx solid #4CAF50;
}

.station-list {
    display: flex;
    flex-direction: column;
    gap: 20rpx;
}

.station-card {
    background: #fff;
    border-radius: 16rpx;
    padding: 30rpx;
    box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
    border: 2rpx solid transparent;
    transition: all 0.3s;
}

.station-card.selected {
    border-color: #4CAF50;
    background: #f0f9f0;
}

.station-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16rpx;
}

.station-name {
    font-size: 30rpx;
    font-weight: bold;
    color: #333;
}

.select-icon {
    width: 48rpx;
    height: 48rpx;
    background: #4CAF50;
    color: #fff;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 28rpx;
    font-weight: bold;
}

.station-info {
    margin-bottom: 12rpx;
}

.info-text {
    font-size: 26rpx;
    color: #666;
    line-height: 1.5;
}

.station-slots {
    padding-top: 16rpx;
    border-top: 1rpx solid #f0f0f0;
}

.slots-text {
    font-size: 24rpx;
    color: #999;
}

.empty-state {
    text-align: center;
    padding: 100rpx 0;
}

.empty-text {
    font-size: 28rpx;
    color: #999;
}

.tips-card {
    background: #fff9e6;
    border-radius: 16rpx;
    padding: 30rpx;
    margin-bottom: 20rpx;
    border: 1rpx solid #ffe58f;
}

.tips-title {
    font-size: 28rpx;
    font-weight: bold;
    color: #faad14;
    margin-bottom: 16rpx;
}

.tips-item {
    font-size: 26rpx;
    color: #666;
    line-height: 1.8;
    margin-bottom: 8rpx;
}

.button-group {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    display: flex;
    gap: 20rpx;
    padding: 20rpx 30rpx;
    background: #fff;
    box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.cancel-btn,
.confirm-btn {
    flex: 1;
    height: 88rpx;
    border-radius: 12rpx;
    font-size: 32rpx;
    font-weight: bold;
    border: none;
}

.cancel-btn {
    background: #f5f5f5;
    color: #666;
}

.confirm-btn {
    background: #4CAF50;
    color: #fff;
}

.cancel-btn::after,
.confirm-btn::after {
    border: none;
}

.loading-container {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    background: #f5f5f5;
}

.loading-text {
    font-size: 28rpx;
    color: #999;
}