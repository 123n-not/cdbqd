<view class="page-return">
  <!-- 加载 -->
  <view class="loading-wrap" wx:if="{{loading}}">
    <text class="loading-icon pulse">🔄</text>
    <text class="loading-text">加载中...</text>
  </view>

  <block wx:if="{{!loading && order}}">
    <!-- 归还头部 -->
    <view class="return-header-card">
      <view class="return-icon-wrap">
        <text class="return-icon">↩️</text>
      </view>
      <text class="return-title">归还充电宝</text>
      <text class="return-subtitle">请选择要归还的投放点</text>
    </view>

    <!-- 订单摘要 -->
    <view class="order-summary-card">
      <view class="summary-row">
        <text class="summary-label">订单号</text>
        <text class="summary-value">#{{order.id}}</text>
      </view>
      <view class="summary-row">
        <text class="summary-label">充电宝</text>
        <text class="summary-value">{{order.powerBankSerialNumber}}</text>
      </view>
      <view class="summary-row">
        <text class="summary-label">借用时间</text>
        <text class="summary-value">{{order.rentTime}}</text>
      </view>
      <view class="summary-tag-row">
        <view class="dot dot-success"></view>
        <text class="text-sm text-primary text-bold">使用中</text>
      </view>
    </view>

    <!-- 选择投放点 -->
    <view class="section-header">
      <text class="section-title">选择归还投放点</text>
      <text class="section-count">{{stations.length}} 个</text>
    </view>

    <view class="station-select-list">
      <block wx:if="{{stations.length > 0}}">
        <view
          class="select-card {{selectedStationId === item.id ? 'selected' : ''}}"
          wx:for="{{stations}}"
          wx:key="id"
          bindtap="onStationSelect"
          data-id="{{item.id}}"
        >
          <view class="select-indicator">
            <view class="radio-circle {{selectedStationId === item.id ? 'checked' : ''}}">
              <text wx:if="{{selectedStationId === item.id}}">✓</text>
            </view>
          </view>
          <view class="select-body">
            <view class="select-name-row">
              <text class="select-name">{{item.name}}</text>
              <view class="tag {{item.availableSlots > 0 ? 'tag-available' : 'tag-full'}}">
                {{item.availableSlots > 0 ? '可归还' : '已满'}}
              </view>
            </view>
            <view class="select-addr">
              <text>{{item.address}}</text>
            </view>
            <view class="select-slots-bar">
              <view class="mini-progress">
                <view class="mini-progress-fill" style="width: {{item.availableSlots / item.totalSlots * 100}}%;"></view>
              </view>
              <text class="mini-progress-text">{{item.availableSlots}}/{{item.totalSlots}} 可用</text>
            </view>
          </view>
        </view>
      </block>

      <view class="empty-state" wx:if="{{stations.length === 0}}">
        <text class="empty-icon-large">🗺️</text>
        <text class="empty-title">暂无可用投放点</text>
        <text class="empty-desc">附近没有投放点可供归还充电宝</text>
      </view>
    </view>

    <!-- 提示 -->
    <view class="tips-banner">
      <text class="tips-icon">💡</text>
      <text class="tips-text">归还后系统将自动根据使用时长计算费用</text>
    </view>
  </block>

  <!-- 底部按钮 -->
  <view class="fixed-bottom" wx:if="{{!loading && order}}">
    <view class="btn-row">
      <button class="btn btn-outline flex-1" bindtap="onCancel">取 消</button>
      <button class="btn btn-primary flex-1 {{!selectedStationId ? 'btn-disabled' : ''}}" bindtap="onConfirmReturn" disabled="{{!selectedStationId}}">
        确认归还
      </button>
    </view>
  </view>
</view>
