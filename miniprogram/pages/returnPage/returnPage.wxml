<view class="return-container" wx:if="{{!loading && order}}">
    <view class="info-card">
        <view class="card-title">订单信息</view>

        <view class="info-row">
            <text class="info-label">订单号：</text>
            <text class="info-value">{{order.id}}</text>
        </view>

        <view class="info-row">
            <text class="info-label">充电宝编号：</text>
            <text class="info-value">{{order.powerBankSerialNumber}}</text>
        </view>

        <view class="info-row">
            <text class="info-label">借用时间：</text>
            <text class="info-value">{{order.rentTime}}</text>
        </view>

        <view class="info-row">
            <text class="info-label">状态：</text>
            <text class="info-value status">使用中</text>
        </view>
    </view>

    <view class="station-section">
        <view class="section-title">选择归还投放点</view>

        <view class="station-list">
            <block wx:if="{{stations.length > 0}}">
                <view
                        class="station-card {{selectedStationId === item.id ? 'selected' : ''}}"
                        wx:for="{{stations}}"
                        wx:key="id"
                        bindtap="onStationSelect"
                        data-id="{{item.id}}"
                >
                    <view class="station-header">
                        <text class="station-name">{{item.name}}</text>
                        <view class="select-icon" wx:if="{{selectedStationId === item.id}}">✓</view>
                    </view>

                    <view class="station-info">
                        <text class="info-text">📍 {{item.address}}</text>
                    </view>

                    <view class="station-slots">
                        <text class="slots-text">可用槽位：{{item.availableSlots}}/{{item.totalSlots}}</text>
                    </view>
                </view>
            </block>

            <view class="empty-state" wx:if="{{stations.length === 0}}">
                <text class="empty-text">暂无可用投放点</text>
            </view>
        </view>
    </view>

    <view class="tips-card">
        <view class="tips-title">💡 温馨提示</view>
        <view class="tips-item">• 请选择有可用槽位的投放点</view>
        <view class="tips-item">• 归还后请确认充电宝已放入槽位</view>
        <view class="tips-item">• 费用将根据使用时长计算</view>
    </view>

    <view class="button-group">
        <button class="cancel-btn" bindtap="onCancel">取消</button>
        <button class="confirm-btn" bindtap="onConfirmReturn">确认归还</button>
    </view>
</view>

<view class="loading-container" wx:if="{{loading}}">
    <text class="loading-text">加载中...</text>
</view>