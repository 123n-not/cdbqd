<view class="page-login">
  <!-- 背景装饰圆 -->
  <view class="bg-circle bg-circle-1"></view>
  <view class="bg-circle bg-circle-2"></view>

  <!-- Logo 和标题 -->
  <view class="login-header">
    <view class="logo-wrap">
      <image class="logo-img" src="/images/logo2.png" mode="aspectFit"></image>
    </view>
    <text class="app-name">共享充电宝</text>
    <text class="app-slogan">随时随地 · 扫码即借</text>
  </view>

  <!-- 登录/注册卡片 -->
  <view class="login-card">
    <!-- 切换 Tab -->
    <view class="mode-tabs">
      <view class="mode-tab {{isLogin ? 'active' : ''}}" bindtap="switchToLogin">
        <text>登录</text>
      </view>
      <view class="mode-tab {{!isLogin ? 'active' : ''}}" bindtap="switchToRegister">
        <text>注册</text>
      </view>
    </view>

    <!-- 表单 -->
    <view class="form-area">
      <view class="input-group">
        <view class="input-label">用户名</view>
        <view class="input-wrap">
          <text class="input-prefix">👤</text>
          <input
            class="input-field-clean"
            placeholder="请输入用户名"
            value="{{username}}"
            bindinput="onUsernameInput"
          />
        </view>
      </view>

      <view class="input-group">
        <view class="input-label">密码</view>
        <view class="input-wrap">
          <text class="input-prefix">🔒</text>
          <input
            class="input-field-clean"
            placeholder="请输入密码（至少6位）"
            password="{{showPassword ? false : true}}"
            value="{{password}}"
            bindinput="onPasswordInput"
          />
          <view class="input-eye" bindtap="togglePassword">
            <text>{{showPassword ? '👁️' : '👁️‍🗨️'}}</text>
          </view>
        </view>
      </view>

      <!-- 提交按钮 -->
      <button class="btn btn-primary submit-btn" bindtap="handleSubmit" loading="{{submitting}}">
        {{isLogin ? '登 录' : '注 册'}}
      </button>
    </view>
  </view>

  <!-- 底部版权 -->
  <view class="login-footer">
    <text>共享充电宝系统 v1.0</text>
  </view>
</view>
