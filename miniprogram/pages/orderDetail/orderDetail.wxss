/* ============================================
   订单详情页
   ============================================ */

.page-order-detail {
  min-height: 100vh;
  background: var(--bg-page);
  padding-bottom: 40rpx;
}

/* --- 加载 --- */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
  gap: 24rpx;
}

.loading-icon {
  font-size: 100rpx;
}

.loading-text {
  font-size: 28rpx;
  color: var(--text-hint);
}

/* --- 状态头部 --- */
.detail-status-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 32rpx 40rpx;
  margin: 16rpx 24rpx 0;
  border-radius: var(--radius-lg);
  color: #fff;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.1);
}

.detail-status-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.detail-status-text {
  font-size: 36rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
}

.detail-status-desc {
  font-size: 24rpx;
  opacity: 0.8;
  margin-top: 8rpx;
}

/* --- 进度条 --- */
.progress-steps {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx 40rpx;
  margin: 16rpx 24rpx;
  background: #fff;
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
}

.step {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  flex-shrink: 0;
}

.step-dot-wrap {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #eef0f4;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s;
}

.step.done .step-dot-wrap {
  background: var(--primary);
}

.step-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #ccc;
}

.step.done .step-dot {
  background: #fff;
}

.step-label {
  font-size: 22rpx;
  color: var(--text-hint);
}

.step.done .step-label {
  color: var(--primary);
  font-weight: 600;
}

.step-line {
  flex: 1;
  height: 3rpx;
  background: #eef0f4;
  margin: 0 8rpx;
  margin-bottom: 28rpx;
  transition: background 0.4s;
}

.step-line.done {
  background: var(--primary);
}

/* --- 信息卡片 --- */
.detail-card {
  background: #fff;
  border-radius: var(--radius-md);
  margin: 0 24rpx 18rpx;
  box-shadow: var(--shadow-sm);
  overflow: hidden;
}

.detail-card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid var(--border);
}

.detail-card-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.detail-card-badge {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--primary);
  font-family: 'SF Mono', 'Menlo', monospace;
}

.detail-list {
  padding: 12rpx 28rpx 20rpx;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.detail-row:last-child {
  border-bottom: none;
}

.detail-label {
  font-size: 26rpx;
  color: var(--text-hint);
}

.detail-value {
  font-size: 26rpx;
  color: var(--text-primary);
  font-weight: 500;
  text-align: right;
  max-width: 60%;
}

/* --- 实时计费卡片 --- */
.fee-live-card {
  border: 2rpx solid #FFE082;
}

.fee-live-header {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 24rpx 28rpx;
  background: #FFF8E1;
  border-bottom: 1rpx solid #FFE082;
}

.fee-live-body {
  padding: 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.fee-timer {
  margin-bottom: 20rpx;
}

.timer-text {
  font-size: 36rpx;
  font-weight: 700;
  color: #E65100;
  font-family: 'SF Mono', 'Menlo', monospace;
}

.fee-live-divider {
  width: 120rpx;
  height: 2rpx;
  background: var(--border);
  margin-bottom: 20rpx;
}

.fee-amount-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.fee-live-label {
  font-size: 26rpx;
  color: var(--text-hint);
}

.fee-live-price {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.fee-live-symbol {
  font-size: 32rpx;
  font-weight: 700;
  color: #FF5722;
}

.fee-live-num {
  font-size: 64rpx;
  font-weight: 800;
  color: #FF5722;
  font-family: 'SF Mono', 'Menlo', monospace;
  line-height: 1;
}

.fee-rate-hint {
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--border);
  width: 100%;
  text-align: center;
}

.fee-rate-hint text {
  font-size: 24rpx;
  color: var(--text-hint);
}

/* --- 费用结算 --- */
.fee-settled-block {
  padding: 40rpx;
  text-align: center;
}

.fee-settled-label {
  display: block;
  font-size: 28rpx;
  color: var(--text-hint);
  margin-bottom: 12rpx;
}

.fee-settled-amount {
  font-size: 64rpx;
  font-weight: 800;
  color: var(--primary);
  font-family: 'SF Mono', 'Menlo', monospace;
}

/* --- 操作区 --- */
.detail-action {
  padding: 20rpx 24rpx;
}

.detail-action .btn {
  width: 100%;
  height: 92rpx;
  font-size: 32rpx;
}
