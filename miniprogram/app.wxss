page {
    background-color: #f5f5f5;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen', 'Ubuntu', 'Cantarell', 'Fira Sans', 'Droid Sans', 'Helvetica Neue', sans-serif;
    font-size: 28rpx;
    color: #333;
}

.container {
    padding: 30rpx;
    box-sizing: border-box;
}

.card {
    background: #fff;
    border-radius: 16rpx;
    padding: 30rpx;
    margin-bottom: 20rpx;
    box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.btn-primary {
    background: #4CAF50;
    color: #fff;
    border-radius: 8rpx;
    font-size: 32rpx;
    padding: 20rpx 40rpx;
}

.btn-secondary {
    background: #fff;
    color: #4CAF50;
    border: 2rpx solid #4CAF50;
    border-radius: 8rpx;
    font-size: 32rpx;
    padding: 20rpx 40rpx;
}

.text-primary {
    color: #4CAF50;
}

.text-secondary {
    color: #999;
}

.text-danger {
    color: #f44336;
}

.flex {
    display: flex;
}

.flex-between {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.flex-center {
    display: flex;
    justify-content: center;
    align-items: center;
}

.mt-20 {
    margin-top: 20rpx;
}

.mb-20 {
    margin-bottom: 20rpx;
}