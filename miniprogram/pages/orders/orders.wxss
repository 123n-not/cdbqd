/* ============================================
   订单列表页
   ============================================ */

.page-orders {
  min-height: 100vh;
  background: var(--bg-page);
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* --- 筛选标签 --- */
.filter-tabs {
  display: flex;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  background: #fff;
  position: sticky;
  top: 0;
  z-index: 10;
  box-shadow: var(--shadow-sm);
}

.filter-tab {
  padding: 12rpx 28rpx;
  border-radius: var(--radius-full);
  font-size: 26rpx;
  font-weight: 500;
  color: var(--text-secondary);
  background: #f5f5f5;
  transition: all 0.2s;
}

.filter-tab.active {
  background: var(--primary);
  color: #fff;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(76,175,80,0.3);
}

/* --- 骨架屏 --- */
.order-skeleton {
  background: #fff;
  border-radius: var(--radius-md);
  padding: 28rpx;
  margin: 0 24rpx 18rpx;
  box-shadow: var(--shadow-sm);
}

/* --- 订单列表 --- */
.order-list {
  padding: 20rpx 24rpx;
}

/* --- 订单卡片 --- */
.order-card {
  display: flex;
  background: #fff;
  border-radius: var(--radius-md);
  margin-bottom: 18rpx;
  box-shadow: var(--shadow-sm);
  overflow: hidden;
  transition: all 0.2s;
}

.order-card:active {
  transform: scale(0.985);
  box-shadow: var(--shadow-md);
}

.order-status-bar {
  width: 8rpx;
  flex-shrink: 0;
  border-radius: 4rpx;
  margin: 20rpx 0 20rpx 18rpx;
}

.order-body {
  flex: 1;
  padding: 20rpx 22rpx 24rpx 18rpx;
  min-width: 0;
}

.order-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.order-serial {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary);
  font-family: 'SF Mono', 'Menlo', monospace;
}

/* --- 信息网格 --- */
.order-info-grid {
  display: flex;
  flex-wrap: wrap;
}

.order-info-item {
  width: 50%;
  display: flex;
  flex-direction: column;
  margin-bottom: 14rpx;
}

.order-info-item.full-width {
  width: 100%;
  flex-direction: row;
  gap: 12rpx;
}

.info-label {
  font-size: 22rpx;
  color: var(--text-hint);
  margin-bottom: 4rpx;
}

.order-info-item.full-width .info-label {
  margin-bottom: 0;
  min-width: 50rpx;
}

.info-value {
  font-size: 25rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.single-line {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* --- 实时计费 --- */
.order-fee-area {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx;
  margin-top: 12rpx;
  background: #FFF8E1;
  border-radius: var(--radius-sm);
}

.fee-running {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.fee-duration {
  font-size: 26rpx;
  font-weight: 600;
  color: #E65100;
}

.fee-amount-fresh {
  display: flex;
  align-items: baseline;
  gap: 2rpx;
}

.fee-symbol {
  font-size: 24rpx;
  font-weight: 700;
  color: #FF5722;
}

.fee-number {
  font-size: 38rpx;
  font-weight: 800;
  color: #FF5722;
  font-family: 'SF Mono', 'Menlo', monospace;
}

/* 已结算 */
.order-fee-area.settled {
  background: #E8F5E9;
  justify-content: flex-end;
  gap: 12rpx;
}

.settled-label {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.settled-amount {
  font-size: 38rpx;
  font-weight: 800;
  color: var(--primary);
  font-family: 'SF Mono', 'Menlo', monospace;
}

/* --- 操作按钮 --- */
.order-action {
  margin-top: 16rpx;
}

.order-action .btn-sm {
  width: 100%;
}

/* --- 空状态 --- */
.empty-icon-large {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.empty-action {
  margin-top: 20rpx;
}

.link-text {
  font-size: 26rpx;
  color: var(--primary);
  font-weight: 500;
}
