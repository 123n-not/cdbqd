<view class="rent-container" wx:if="{{!loading && powerBank && station}}">
    <view class="info-card">
        <view class="card-title">充电宝信息</view>

        <view class="info-row">
            <text class="info-label">编号：</text>
            <text class="info-value">{{powerBank.serialNumber}}</text>
        </view>

        <view class="info-row">
            <text class="info-label">电量：</text>
            <text class="info-value highlight">{{powerBank.batteryLevel}}%</text>
        </view>

        <view class="info-row">
            <text class="info-label">状态：</text>
            <text class="info-value status">可借用</text>
        </view>
    </view>

    <view class="info-card">
        <view class="card-title">投放点信息</view>

        <view class="info-row">
            <text class="info-label">名称：</text>
            <text class="info-value">{{station.name}}</text>
        </view>

        <view class="info-row">
            <text class="info-label">地址：</text>
            <text class="info-value">{{station.address}}</text>
        </view>
    </view>

    <view class="tips-card">
        <view class="tips-title">💡 温馨提示</view>
        <view class="tips-item">• 借用后请妥善保管充电宝</view>
        <view class="tips-item">• 使用完毕请及时归还</view>
        <view class="tips-item">• 归还时请选择任意投放点</view>
        <view class="tips-item">• 超时未归还将产生额外费用</view>
    </view>

    <view class="button-group">
        <button class="cancel-btn" bindtap="onCancel">取消</button>
        <button class="confirm-btn" bindtap="onConfirmRent">确认借用</button>
    </view>
</view>

<view class="loading-container" wx:if="{{loading}}">
    <text class="loading-text">加载中...</text>
</view>